# Supabase Configuration
#
# Local (Docker required): https://supabase.com/docs/guides/local-development
#   npx supabase start
#
# Hosted: Dashboard → Settings → Project URL + anon key (same project).
#
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0

# Client hint for admin UI (NOT a security boundary — server uses admin_email_allowlist table)
VITE_ADMIN_EMAILS=your-new-admin-email@example.com

# After setting VITE_ADMIN_EMAILS, also run in Supabase SQL Editor:
# INSERT INTO public.admin_email_allowlist (email) VALUES ('your-new-admin-email@example.com');

# Optional: App Configuration
VITE_APP_NAME=BeePro Academy
VITE_APP_URL=http://localhost:3000

# Optional: Google Calendar API
VITE_GOOGLE_CALENDAR_CLIENT_ID=your_google_calendar_client_id

# Required for embedded Jitsi video meetings.
# Do not use meet.jit.si for in-platform calls: public room creation requires
# Google/GitHub/Facebook authentication. Use your self-hosted Jitsi domain
# with anonymous guests enabled, or an 8x8 JaaS tenant domain.
VITE_JITSI_DOMAIN=meet.your-domain.com

# Supabase Auth: if signup shows "Error sending confirmation email", open Supabase Dashboard
# → Authentication → Providers → Email → disable "Confirm email", OR configure SMTP under Project Settings → Auth.

# Analytics & Pixels (leave empty to disable)
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
VITE_GTM_ID=GTM-5WSS8NFP
VITE_META_PIXEL_ID=
VITE_TIKTOK_PIXEL_ID=
VITE_SNAPCHAT_PIXEL_ID=
VITE_LINKEDIN_PARTNER_ID=
