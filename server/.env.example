# ============================================
# BePro Academy — Server Environment Variables
# ============================================

# Database (Supabase PostgreSQL direct connection)
# Find this in: Supabase Dashboard → Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# JWT
JWT_SECRET=change-me-to-a-random-string-min-32-characters-long
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Server
PORT=5000
NODE_ENV=development
# CLIENT_URL can be a comma-separated list of allowed origins
CLIENT_URL=http://localhost:3000,https://bee-pro-academy.vercel.app

# Google OAuth (optional — leave empty to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# Email / SMTP (optional — leave empty to use console stub)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@beepro.academy
